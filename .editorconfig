root = true

# All files
[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# Shell scripts
[*.sh]
indent_size = 4

# BATS test files
[*.bats]
indent_size = 4

# YAML files
[*.{yml,yaml}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = 120

# Makefile (must use tabs)
[Makefile]
indent_style = tab
indent_size = 4
